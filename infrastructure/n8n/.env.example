# Copy this file to .env on the automation VM and replace every change-me value.
# Never commit the real .env file.

N8N_IMAGE=docker.n8n.io/n8nio/n8n:2.27.5
POSTGRES_IMAGE=postgres:17.10-bookworm

N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=change-me-with-a-random-database-password
N8N_ENCRYPTION_KEY=change-me-with-at-least-64-random-hex-characters

GENERIC_TIMEZONE=Europe/Budapest
TZ=Europe/Budapest
