        "jsCode": "const items = $input.all();\nconst feedText = items.map(item => `- Title: ${item.json.title}\\n  Link: ${item.json.link}\\n  Snippet: ${item.json.contentSnippet}`).join('\\n\\n');\nreturn [{ json: { feedContent: feedText } }];"
