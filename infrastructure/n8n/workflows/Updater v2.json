        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"goal\": \"Analyze the following n8n releases feed:\\n\\n{{ $json.feedContent }}\\n\\nDetermine if there is a new stable release that is newer than our currently installed version in 'infrastructure/n8n/compose.yaml'. If so, update the compose.yaml file to use the new stable version. Show the diff and ask for approval.\",\n  \"max_steps\": 10\n}",
