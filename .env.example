# Copy this file to .env and adjust values locally.
# Never commit the resulting .env file.

KELVIN_ENVIRONMENT=development
KELVIN_LOG_LEVEL=INFO
KELVIN_LOG_FORMAT=console

KELVIN_API_HOST=127.0.0.1
KELVIN_API_PORT=8000
KELVIN_API_AUTH_MODE=disabled
# Production or LAN-accessible deployments must require auth.
# Store only SHA-256 token digests in this file; never raw bearer tokens.
# KELVIN_API_AUTH_MODE=required
# KELVIN_API_TOKEN_FILE=/etc/kelvin-assistant/api-tokens.json
# File updated by the Settings UI. On the VM this should point to the systemd
# EnvironmentFile so saved settings survive restarts.
# KELVIN_SETTINGS_ENV_FILE=/etc/kelvin-assistant/kelvin.env

# Local development uses Ollama on the same Windows host.
# An Ubuntu VM must use the Windows host's LAN address instead of 127.0.0.1.
KELVIN_LLM_PROVIDER=ollama
KELVIN_OLLAMA_BASE_URL=http://127.0.0.1:11434
KELVIN_OLLAMA_MODEL=gemma4:e4b
KELVIN_OLLAMA_EMBEDDING_MODEL=nomic-embed-text
KELVIN_EMBEDDING_DIMENSION=768
KELVIN_OLLAMA_TIMEOUT=120

# Kelvin alapértelmezett nyelve és válaszstílusa. Igény szerint felülírható.
# KELVIN_SYSTEM_PROMPT=Válaszolj természetes, helyes magyar nyelven.

# PostgreSQL + pgvector knowledge store.
# KELVIN_DATABASE_URL=postgresql://kelvin:<password>@127.0.0.1:5432/kelvin_assistant
KELVIN_DATABASE_CONNECT_TIMEOUT=5

# Optional RAG context for chat.
KELVIN_RAG_ENABLED=false
KELVIN_RAG_COLLECTION=manual
KELVIN_RAG_RESULT_LIMIT=3

# Optional n8n status and delegated notification settings.
# KELVIN_N8N_URL=http://<N8N_HOST>:5678
# KELVIN_N8N_TOKEN=<stored-outside-git>

# Optional email notifications. Prefer configuring these in the local UI or in
# /etc/kelvin-assistant/kelvin.env on the VM. Never commit SMTP credentials.
KELVIN_EMAIL_NOTIFICATIONS_ENABLED=false
KELVIN_EMAIL_PROVIDER_MODE=smtp
KELVIN_EMAIL_SMTP_HOST=localhost
KELVIN_EMAIL_SMTP_PORT=1025
KELVIN_EMAIL_SMTP_USERNAME=
KELVIN_EMAIL_SMTP_PASSWORD=
KELVIN_EMAIL_SMTP_USE_TLS=false
KELVIN_EMAIL_SENDER=kelvin@localhost
# KELVIN_EMAIL_RECIPIENT=user@example.com
KELVIN_EMAIL_DAILY_SUMMARY_TIME=18:00
KELVIN_EMAIL_ON_APPROVAL_REQUIRED=true
KELVIN_EMAIL_ON_RUN_COMPLETED=true
KELVIN_EMAIL_ON_RUN_FAILED=true
KELVIN_EMAIL_ON_DAILY_SUMMARY=true

# Agent workspace IDs are opaque names shared by the backend and Windows client.
# The Windows client will map each ID to a canonical local path.
# KELVIN_AGENT_WORKSPACE_IDS=["kelvin-assistant"]

# Windows kelvin client settings. The workspace path stays local.
# KELVIN_API_URL=http://192.168.10.13:8000
# KELVIN_API_TIMEOUT_SECONDS=120
# KELVIN_WORKSPACE_ID=kelvin-assistant
# KELVIN_WORKSPACE_PATH=C:\Users\Zoltan\Documents\Kelvin Assistant
