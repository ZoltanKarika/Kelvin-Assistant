# Copy this file to .env and adjust values locally.
# Never commit the resulting .env file.

KELVIN_ENVIRONMENT=development
KELVIN_LOG_LEVEL=INFO
KELVIN_LOG_FORMAT=console

KELVIN_API_HOST=127.0.0.1
KELVIN_API_PORT=8000

# Local development uses Ollama on the same Windows host.
# An Ubuntu VM must use the Windows host's LAN address instead of 127.0.0.1.
KELVIN_LLM_PROVIDER=ollama
KELVIN_OLLAMA_BASE_URL=http://127.0.0.1:11434
KELVIN_OLLAMA_MODEL=gemma4:e4b
KELVIN_OLLAMA_TIMEOUT=120

# Reserved for later milestones.
# KELVIN_CHROMA_PATH=./data/chroma
# KELVIN_AGENT_APPROVAL_MODE=ask
