{
  "_comment": [
    "This is an EXAMPLE file. Copy it to 'api-tokens.json' and replace the",
    "token_sha256 values with real SHA-256 hashes of your own secret tokens.",
    "",
    "To generate a token hash in PowerShell:",
    "  $token = 'your-secret-token-here'",
    "  $bytes = [System.Text.Encoding]::ASCII.GetBytes($token)",
    "  $sha256 = [System.Security.Cryptography.SHA256]::Create()",
    "  ($sha256.ComputeHash($bytes) | ForEach-Object { $_.ToString('x2') }) -join ''",
    "",
    "Or in Python:",
    "  import hashlib",
    "  hashlib.sha256(b'your-secret-token-here').hexdigest()",
    "",
    "NEVER commit the real api-tokens.json to Git.",
    "It is listed in .gitignore."
  ],
  "version": 1,
  "tokens": [
    {
      "id": "n8n-research",
      "_comment": "n8n automation workflows - read-only research access",
      "token_sha256": "REPLACE_WITH_SHA256_OF_YOUR_SECRET_TOKEN_1",
      "scopes": [
        "chat:use",
        "memory:read",
        "system:read"
      ]
    },
    {
      "id": "ps-client",
      "_comment": "Local PowerShell Windows client - full agent loop access",
      "token_sha256": "REPLACE_WITH_SHA256_OF_YOUR_SECRET_TOKEN_2",
      "scopes": [
        "system:read",
        "chat:use",
        "knowledge:read",
        "memory:read",
        "memory:write",
        "agent:execute",
        "agent:write",
        "agent:approve"
      ]
    }
  ]
}
