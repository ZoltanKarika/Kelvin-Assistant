# Normalize text in the repository and make cross-platform checkouts predictable.
* text=auto

# Linux, Python, and documentation files
*.py text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.sh text eol=lf
*.service text eol=lf
*.env text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Windows PowerShell files
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.gguf binary
